{
  "id": "characterbench",
  "title": "CharacterBench",
  "description": "Evolve the solver against CharacterBench with CharacterJudge-style response scoring.",
  "benchmark_tier": "comparable",
  "included_in_main_comparison": true,
  "track": "personalization_verified",
  "research_line": "personalization",
  "personalization_category": "role_play",
  "personalization_focus": "character_control",
  "dataset_id": "characterbench_characterjudge",
  "dataset_size": 3250,
  "local_dataset_only": true,
  "lazy_item_manifest": true,
  "item_manifest": "data/questions.json",
  "split": "official:raw_data:all-tests",
  "allow_browsing": false,
  "answer_metric": "characterjudge_score",
  "family": "personalization",
  "runtime_backend": "dataset",
  "task_mode": "answer",
  "interaction_mode": "single_turn",
  "optimization_scope": "implementation",
  "task_shape": "dialogue_judgement",
  "scoring_mode": "judge_model",
  "supports_eval_model": true,
  "requires_eval_model": true,
  "default_eval_model": null,
  "task_signature": [
    "editable-file-optimization",
    "single-turn",
    "dataset-task",
    "personalization",
    "role-play",
    "character-control",
    "llm-judge"
  ],
  "editable_file": "editable.py",
  "verifier": "verifier.py",
  "entry_symbol": "solve",
  "function_name": "solve",
  "generation_budget": 4,
  "candidate_budget": 3,
  "branching_factor": 4,
  "item_workers": 4,
  "epsilon": 0.02,
  "baseline_summary": "A baseline character-response solver that mirrors the current user message with minimal style adaptation.",
  "objective_spec": {
    "display_name": "CharacterJudge Score",
    "direction": "max",
    "unit": "ratio",
    "summary_template": "Higher normalized CharacterJudge score is better across the full CharacterBench benchmark.",
    "formula": "characterjudge_score = mean(judge_score / subset_max_annotation_score)"
  },
  "prompt_context": "Edit editable.py only. The entry symbol solve(question: dict) must return the next character response text for the current CharacterBench item."
}
