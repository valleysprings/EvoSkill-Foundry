{
  "id": "ag_news_small",
  "task_family": "topic-classification",
  "dataset": "sh0416/ag_news",
  "source_url": "https://huggingface.co/datasets/sh0416/ag_news",
  "license": "Research-use benchmark derivative",
  "config": "default",
  "metrics": [
    "accuracy"
  ],
  "record_format": {
    "input_fields": [
      "title",
      "description",
      "article"
    ],
    "target_field": "label_text"
  },
  "notes": "Four-way topic classification benchmark for prompt architecture comparisons.",
  "splits": {
    "train": {
      "path": "benchmarks/prompt/data/ag_news_small/train.jsonl",
      "num_rows": 80,
      "source_split": "train",
      "offset": 0,
      "length": 80
    },
    "eval": {
      "path": "benchmarks/prompt/data/ag_news_small/eval.jsonl",
      "num_rows": 60,
      "source_split": "test",
      "offset": 0,
      "length": 60
    }
  }
}