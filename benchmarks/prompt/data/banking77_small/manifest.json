{
  "id": "banking77_small",
  "task_family": "intent-routing",
  "dataset": "mteb/banking77",
  "source_url": "https://huggingface.co/datasets/mteb/banking77",
  "license": "MIT",
  "config": "default",
  "metrics": [
    "accuracy"
  ],
  "record_format": {
    "input_fields": [
      "text"
    ],
    "target_field": "label_text"
  },
  "notes": "Small intent-routing benchmark for local prompt evolution.",
  "splits": {
    "train": {
      "path": "benchmarks/prompt/data/banking77_small/train.jsonl",
      "num_rows": 80,
      "source_split": "train",
      "offset": 0,
      "length": 80
    },
    "eval": {
      "path": "benchmarks/prompt/data/banking77_small/eval.jsonl",
      "num_rows": 60,
      "source_split": "test",
      "offset": 0,
      "length": 60
    }
  }
}