{
  "id": "boolq_small",
  "task_family": "yes-no-qa",
  "dataset": "google/boolq",
  "source_url": "https://huggingface.co/datasets/google/boolq",
  "license": "CC-BY-SA-3.0",
  "config": "default",
  "splits": {
    "train": {
      "source_split": "train",
      "offset": 0,
      "length": 80
    },
    "eval": {
      "source_split": "validation",
      "offset": 0,
      "length": 60
    }
  },
  "record_format": {
    "input_fields": [
      "question",
      "passage"
    ],
    "target_field": "answer"
  },
  "metrics": [
    "accuracy"
  ],
  "notes": "Binary QA benchmark that is cheap to evaluate."
}
